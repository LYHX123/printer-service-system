# Copy this file to ".env.production" on the server.
# Loaded by the "app" container (docker-compose env_file).
# Keep this file out of git (.env* is already gitignored).

NODE_ENV=production

# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB in ".env"
# "db" is the docker-compose service name for Postgres
DATABASE_URL=postgresql://printerapp:changeme-strong-password@db:5432/printer_service?schema=public

# NextAuth
# Generate with: openssl rand -base64 32
AUTH_SECRET=changeme-generate-a-random-32-byte-secret
AUTH_TRUST_HOST=true
AUTH_URL=https://printerservice.yourcompany.com

# App display name
NEXT_PUBLIC_APP_NAME=Printer Service System
